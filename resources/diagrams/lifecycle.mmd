flowchart LR
    subgraph BS["BOOTSTRAP — one-time"]
        direction TB
        init["/solo-npm:init"]
        trust["/solo-npm:trust"]
        init --> trust
    end
    subgraph PR["PER RELEASE — daily"]
        direction TB
        verify["/solo-npm:verify"]
        release["/solo-npm:release"]
        verify --> release
    end
    subgraph LT["TRANSITIONS — rare"]
        direction TB
        prerelease["/solo-npm:prerelease"]
        hotfix["/solo-npm:hotfix"]
    end
    subgraph OP["OPERATE — continuous"]
        direction TB
        status["/solo-npm:status"]
        audit["/solo-npm:audit"]
        deps["/solo-npm:deps"]
        distTag["/solo-npm:dist-tag"]
        deprecate["/solo-npm:deprecate"]
        owner["/solo-npm:owner"]
        audit --> deps
        audit -.-> deprecate
        status -.-> distTag
    end
    BS ==> PR
    PR <-.auto-chain.-> LT
    PR -.cache-aware.-> OP
    PR -.post-major.-> deprecate
